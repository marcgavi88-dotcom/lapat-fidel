# Supabase - obtén estos valores desde https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_publica_anon
SUPABASE_SERVICE_ROLE_KEY=tu_clave_secreta_service_role

# URL pública de tu app (cuando esté en Vercel, pon el dominio final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend para envío de emails - obtén la API key en https://resend.com/api-keys
RESEND_API_KEY=re_tu_api_key
RESEND_FROM_EMAIL=fidelitat@apatdelprat.es
